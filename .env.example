# =============================================================================
# .env.example — Manicure Fácil
# Copie este arquivo para .env e preencha com seus valores
# =============================================================================
# cp .env.example .env
#
# SECURITY: Nunca commite o .env no git. Ele já está no .gitignore.

# ── Supabase ────────────────────────────────────────────────────────────────
# Obrigatório. Crie um projeto em https://supabase.com
# Acesse: Project Settings → API → Project URL / anon key / service_role key
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua-chave-anon-publica
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# ── Node ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── Lovable (opcional — apenas se usar Lovable Cloud Auth) ─────────────────
# LOVABLE_API_KEY=

# ── AI Assistant (opcional — necessário para o Assistente IA real) ─────────
# Escolha o provedor: "openai" (padrão) ou "gemini"
AI_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-sua-chave-aqui
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=2048
